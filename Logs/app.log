import time
import sys
import os
from PySide6.QtCore import QObject, Signal, Slot

# 统一路径规范
sys.path.append(os.path.dirname(os.path.dirname(os.path.abspath(__file__))))
from Core.clipboard_mgr import ClipboardManager
from Core.image_generator import ImageGenerator
from Core.logger import logger

class ChatBoxController(QObject):
    """
    核心工作流控制器 (两步走：装填 -> 发射)
    负责桥接: 键盘监听 <-> HUD悬浮窗 <-> 剪贴板管理 <-> 图像引擎
    """
    arm_signal = Signal(dict)
    execute_signal = Signal()

    def __init__(self, clipboard_mgr: ClipboardManager, image_gen: ImageGenerator):
        super().__init__()
        self.clipboard_mgr = clipboard_mgr
        self.image_gen = image_gen
        
        self.is_running = False
        self.active_hotkeys = []  
        self.emotes_configs = []  
        self.global_settings = {}
        
        self.armed_emote_cfg = None 
        self.hud_callback = None
        
        # 绑定信号到主线程槽函数
        self.arm_signal.connect(self._process_arm)
        self.execute_signal.connect(self._process_execute)

    def start_listening(self, emotes_configs: list, global_settings: dict, hud_callback=None):
        """挂载全局钩子"""
        if self.is_running:
            self.stop_listening()

        self.emotes_configs = emotes_configs
        self.global_settings = global_settings
        self.hud_callback = hud_callback
        self.active_hotkeys.clear()

        is_block = self.global_settings.get("block_keys", True)

        # 1. 注册表情装填键
        for cfg in self.emotes_configs:
            if not cfg.get("is_enabled", True):
                continue
            
            hk = cfg.get("hotkey", "").strip().lower()
            if hk:
                try:
                    keyboard.add_hotkey(hk, self._emit_arm, args=(cfg,), suppress=is_block)
                    self.active_hotkeys.append(hk)
                except Exception as e:
                    logger.warning(f"表情 [{cfg.get('name')}] 的快捷键 {hk} 注册失败: {e}")

        # 2. 注册全局发射键
        global_hk = self.global_settings.get("global_trigger_key", "alt+enter").lower()
        if global_hk:
            try:
                keyboard.add_hotkey(global_hk, self._emit_execute, suppress=is_block)
                self.active_hotkeys.append(f"全局发送:{global_hk}")
            except Exception as e:
                logger.warning(f"全局发送快捷键 {global_hk} 注册失败: {e}")

        self.is_running = True
        logger.info(f"底层键盘钩子挂载成功，当前监听 {len(self.active_hotkeys)} 个键位。")

    def stop_listening(self):
        """卸载全局钩子"""
        keyboard.unhook_all()
        self.active_hotkeys.clear()
        self.is_running = False
        logger.info("底层键盘钩子已全面卸载。")

    def _emit_arm(self, cfg):
        """子线程：触发装填信号"""
        self.arm_signal.emit(cfg)

    def _emit_execute(self):
        """子线程：触发发射信号"""
        self.execute_signal.emit()

    @Slot(dict)
    def _process_arm(self, cfg: dict):
        """主线程：处理装填逻辑"""
        self.armed_emote_cfg = cfg
        name = cfg.get("name", "未知")
        img_path = os.path.join(cfg.get("_folder_path", ""), cfg.get("base_image", "base.png"))
        
        logger.info(f"已装填表情: {name}")
        
        if self.hud_callback:
            self.hud_callback(name, img_path)

    @Slot()
    def _process_execute(self):
        """主线程：处理发射逻辑"""
        if not self.armed_emote_cfg:
            logger.warning("发送中断：当前没有装填任何表情。")
            return

        name = self.armed_emote_cfg.get("name", "未知")
        logger.info(f"开始发射表情: {name}")
        
        delay = self.global_settings.get("delay_ms", 150) / 1000.0

        # 1. 备份底图
        if self.clipboard_mgr.check_and_backup_image():
            logger.debug("剪贴板底图已备份。")
        else:
            logger.debug("剪贴板无底图，将生成纯文本气泡。")

        # 2. 剪切文字
        logger.debug("模拟执行 Ctrl+A 与 Ctrl+X...")
        keyboard.send('ctrl+a')
        time.sleep(0.02)
        keyboard.send('ctrl+x')
        
        text = self.clipboard_mgr.grab_text_after_cut(delay=delay)
        if text:
            logger.debug(f"获取到文本: '{text}'")
        else:
            logger.debug("未获取到选中文本。")

        # 3. 图像合成
        logger.debug("图像引擎正在合成...")
        try:
            base_image = self.clipboard_mgr.get_cached_image()
            generated_image = self.image_gen.generate(base_image, text, self.armed_emote_cfg)
            self.clipboard_mgr.set_image(generated_image)
            logger.debug("合成图像已写入剪贴板。")
        except Exception as e:
            logger.error(f"图像合成失败: {e}")
            return

        # 4. 粘贴与发送
        logger.debug("模拟执行 Ctrl+V 粘贴...")
        keyboard.send('ctrl+v')
        
        time.sleep(delay)
        
        logger.debug("模拟执行 Enter 发送...")
        keyboard.send('enter')
        
        logger.info(f"表情 [{name}] 发射完毕！")'
