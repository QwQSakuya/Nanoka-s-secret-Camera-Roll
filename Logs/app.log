                logger.warning(f"全局发射键 {global_hk} 注册失败: {e}")

        self.is_running = True
        logger.info(f"键盘底层钩子注入成功 | 当前监控键位: {self.active_hotkeys}")

    def stop_listening(self):
        """卸载全局钩子"""
        keyboard.unhook_all()
        self.active_hotkeys.clear()
        self.is_running = False
        logger.info("键盘底层钩子已卸载")

    def trigger_arm(self, cfg):
        """子线程：触发装填信号"""
        self.arm_signal.emit(cfg)

    def trigger_execute(self):
        """子线程：触发发射信号"""
        self.execute_signal.emit()

    @Slot(dict)
    def _process_arm(self, cfg: dict):
        """主线程：处理装填逻辑"""
        self.armed_emote_cfg = cfg
        name = cfg.get("name", "未知")
        img_path = os.path.join(cfg.get("_folder_path", ""), cfg.get("base_image", "base.png"))
        
        logger.info(f"已装填表情 -> {name}")
        
        if self.hud_callback:
            logger.debug(f"执行 HUD 弹窗指令: {name}")
            self.hud_callback(name, img_path)
            logger.debug("悬浮窗弹窗指令已成功下发至 UI 层。")

    @Slot()
    def _process_execute(self):
        """主线程：处理发射逻辑"""
        if not self.armed_emote_cfg:
            logger.warning("发送中断：当前没有装填任何表情。")
            return

        name = self.armed_emote_cfg.get("name", "未知")
        logger.info(f"========== 发射表情: {name} ==========")
        
        delay = self.global_settings.get("delay_ms", 150) / 1000.0

        # 1. 备份底图
        has_base_image = self.clipboard_mgr.check_and_backup_image()
        if has_base_image:
            img_size = self.clipboard_mgr.get_cached_image().size
            logger.debug(f"成功备份底图尺寸: {img_size}")
        else:
            logger.debug("剪贴板无底图，将生成纯文本气泡")

        # 2. 剪切文字
        logger.debug("尝试补发 Ctrl+X...")
        keyboard.send('ctrl+a')
        time.sleep(0.02)
        keyboard.send('ctrl+x')
        
        text = self.clipboard_mgr.grab_text_after_cut(delay=delay)
        
        if text:
            logger.debug(f"获取到文本: '{text}'")
        elif not has_base_image:
            # 还原您原本精准的中断逻辑：如果没文本且没底图，直接取消本次发送
            logger.info("工作流中断 | 没有选中任何文本或底图")
            return

        # 3. 图像合成
        try:
            base_image = self.clipboard_mgr.get_cached_image()
            generated_image = self.image_gen.generate(base_image, text, self.armed_emote_cfg)
            self.clipboard_mgr.set_image(generated_image)
            logger.debug("合成图像已写入剪贴板")
        except Exception as e:
            logger.error(f"图像合成失败: {e}")
            return

        # 4. 粘贴与发送
        logger.debug("尝试粘贴 (Ctrl+V)...")
        keyboard.send('ctrl+v')
        
        time.sleep(delay)
        
        logger.debug("尝试发送 (Enter)...")
        keyboard.send('enter')
        
        logger.info(f"========== {name} 发射完毕 ==========")


if __name__ == "__main__":
    signal.signal(signal.SIGINT, signal.SIG_DFL)
    app = QApplication(sys.argv)
    app.setQuitOnLastWindowClosed(False)

    logger.info("--- 两步走监听器独立测试 ---")
    cb_mgr = ClipboardManager()
    img_gen = ImageGenerator()
    controller = ChatBoxController(cb_mgr, img_gen)
    
    # 构建测试用的伪配置
    test_emotes = [{
        "name": "测试表情",
        "hotkey": "alt+1",
        "is_enabled": True
    }]
    test_global = {
        "global_trigger_key": "alt+enter",
        "block_keys": False,
        "delay_ms": 150
    }
    
    try:
        controller.start_listening(test_emotes, test_global)
        keyboard.add_hotkey('esc', lambda: app.quit())
        sys.exit(app.exec())
    except KeyboardInterrupt:
        pass
    finally:
        controller.stop_listening()'
